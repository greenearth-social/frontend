# Firebase project
FIREBASE_PROJECT_ID=greenearth-471522

# Service account key for Firebase Admin SDK (custom token minting)
# Generate: Firebase console → Project settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Public HTTPS origin for OAuth metadata
# Dev: your tunnel URL (no trailing slash)
# Prod: your Firebase Hosting URL
APP_ORIGIN=https://your-app.tunnel.ts.net

# OAuth client key ID
BLUESKY_OAUTH_CLIENT_KID=key-1

# --- Keys (dev: files in functions/keys/, prod: set as env vars below) ---

# Dev: generate with `node scripts/generate-oauth-keys.cjs`
# Prod: set in Firebase Console → Functions → Environment variables
# BLUESKY_OAUTH_CLIENT_PRIVATE_KEY={"kty":"EC","x":"...","y":"...","crv":"P-256","d":"..."}
# BLUESKY_OAUTH_PUBLIC_JWKS={"keys":[{"kty":"EC","x":"...","y":"...","crv":"P-256","kid":"key-1","use":"sig","alg":"ES256"}]}

# AES-256 key (hex-encoded, 64 chars) for encrypting OAuth state parameter
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# Comment this out if deploying functions from cli because the secret is set as a Firebase secret.
# The deploy script automatically pulls in this .env file and Cloud Functions don't allow the same key in both places.
OAUTH_STATE_ENCRYPTION_KEY=...
