# Frontend Firebase config
# Get these from the Firebase console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=greenearth-471522
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Frontend mode
# Set VITE_USE_MOCK_SERVICES=false to use real Firebase + Firestore
VITE_USE_MOCK_SERVICES=true
# Set VITE_USE_FIREBASE_EMULATORS=false when deploying or testing against real DB
VITE_USE_FIREBASE_EMULATORS=true

# Allowed hosts for Vite dev server (comma-separated)
# Add your tunnel domain here, e.g.: VITE_ALLOWED_HOSTS=localhost,my-app.ngrok-free.app
VITE_ALLOWED_HOSTS=localhost

# Database is configured at runtime via public/config.json, not via env var.
# CI swaps config.json per environment before deploying the same bundle.
