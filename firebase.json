{
  "hosting": {
    "site": "greenearth-471522",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/.well-known/oauth-client-metadata",
        "function": "oauthClientMetadata"
      },
      {
        "source": "/.well-known/jwks.json",
        "function": "oauthJwks"
      },
      {
        "source": "/auth/bluesky",
        "function": "authBluesky"
      },
      {
        "source": "/oauth/callback",
        "function": "oauthCallback"
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "greenearth-api-prod",
          "region": "us-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "greenearth-stage",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "greenearth-prod",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "singleProjectMode": true
  }
}
