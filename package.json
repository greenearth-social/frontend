{
  "name": "greenearth-feed-debug",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@adobe/lit-mobx": "^2.2.2",
    "firebase": "^12.15.0",
    "lit": "^3.2.1",
    "mobx": "^6.13.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "happy-dom": "^17.4.4",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
