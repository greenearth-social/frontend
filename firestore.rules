rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userDocId(did) {
      return did.startsWith('did:plc:') ? did.slice(8) : did;
    }

    // Existing backend document paths — docId strips did:plc: prefix
    match /users/{docId} {
      allow read: if docId == userDocId(request.auth.uid);
    }

    match /users/{docId}/feed_debug/{requestId} {
      allow read: if docId == userDocId(request.auth.uid);
    }

    // Transient OAuth state — written/read/deleted by Cloud Functions
    match /pendingOAuthRequests/{state} {
      allow read, delete: if request.auth != null;
      allow create: if true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
